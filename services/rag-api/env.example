# RAG API Configuration

# OpenAI API Key (required for embeddings)
OPENAI_API_KEY=your-openai-api-key-here

# Admin API key (enables /admin/* endpoints; send as X-Admin-Key header)
ADMIN_API_KEY=your-admin-key-here

# Pipeline Settings
VECTOR_DB_PATH=./vector_db
COLLECTION_NAME=documents
# Separate collection for podcasts corpus (Chroma)
PODCASTS_COLLECTION_NAME=podcasts
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=50
# Optional overrides for podcasts chunking (defaults to CHUNK_* if unset)
# Defaults are tuned for long transcripts (1000/120). Override if desired:
# PODCASTS_CHUNK_MAX_TOKENS=1000
# PODCASTS_CHUNK_OVERLAP_TOKENS=120

# Metadata store (SQLite)
# Local default:
# METADATA_DB_URL=sqlite+aiosqlite:///./metadata.db
# Render persistent disk example (mount at /data):
# METADATA_DB_URL=sqlite+aiosqlite:////data/metadata.db

# Render persistent disk example (mount at /data):
# VECTOR_DB_PATH=/data/vector_db

# IMPORTANT: If you run multiple API instances/replicas, you must use shared storage
# for Chroma + metadata (or run a single instance). Otherwise each instance can have
# different local state and retrieval will appear intermittent.

# Embedding Settings
EMBEDDING_MODEL=text-embedding-3-small

# CORS Settings (for frontend integration)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
